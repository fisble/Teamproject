{
  "name": "skillsync-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "axios": "1.6.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.18.0",
    "react-scripts": "4.0.3"
  },
  "scripts": {
    "start": "set NODE_OPTIONS=--openssl-legacy-provider && npm run build-win",
    "build": "NODE_OPTIONS=--openssl-legacy-provider react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "build-win": "set DANGEROUSLY_DISABLE_HOST_CHECK=true && react-scripts start"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
